-- data was updated so here's ab updated view 
CREATE OR ALTER VIEW v_PowerBI_Census_Analytics AS
SELECT 
    -- 1. Time Dimensions
    y.year_key,
    y.report_year AS census_year,

    -- 2. Geographic Dimensions
    m.metro_key,
    m.cbsa_code AS metro_id,
    m.metro_name,
    m.state_abbreviation AS state_code,

    -- 3. Demographic Dimensions
    ag.age_group_key,
    ag.age_group_label AS age_group,
    d.demographic_group AS race_ethnicity,
    d.gender,

    -- 4. Population Facts
    p.population_count AS age_group_population,

    -- 5. Metro-Level Aggregate Facts
    mm.total_population AS total_metro_population,
    mm.median_age AS metro_median_age,
    mm.growth_count AS metro_growth_count,
    mm.growth_percentage AS metro_growth_percentage

FROM dbo.gold_Populations p
INNER JOIN dbo.gold_Years y ON p.year_key = y.year_key
INNER JOIN dbo.gold_Metros m ON p.metro_key = m.metro_key
INNER JOIN dbo.gold_AgeGroups ag ON p.age_group_key = ag.age_group_key
INNER JOIN dbo.gold_Demographics d ON p.demographic_key = d.demographic_key
INNER JOIN dbo.MetroMetrics mm ON p.year_key = mm.year_key 
                               AND p.metro_key = mm.metro_key;