-- ========================================================
-- 1. DIMENSION TABLES (Create these first)
-- ========================================================

-- Holds the calendar year tracking for census data
CREATE TABLE Years (
    year_key INT PRIMARY KEY,
    census_year INT NOT NULL
);

-- Holds geographical data for plotting on Power BI maps
CREATE TABLE Metros (
    metro_key INT PRIMARY KEY,
    metro_id VARCHAR(10),        -- FIPS/CBSA code
    metro_name VARCHAR(150),     -- e.g., "Oklahoma City, OK"
    state_code CHAR(2),          -- e.g., "OK"
    latitude DECIMAL(9,6),       -- Map plotting
    longitude DECIMAL(9,6)       -- Map plotting
);

-- Holds categorized age ranges for stacked bar charts
CREATE TABLE AgeGroups (
    age_group_key INT PRIMARY KEY,
    age_group VARCHAR(50)        -- e.g., "18-34"
);

-- Holds demographic slices for legends and category splits
CREATE TABLE Demographics (
    demographic_key INT PRIMARY KEY,
    race_ethnicity VARCHAR(100), -- e.g., "Hispanic"
    gender VARCHAR(20)           -- e.g., "Female"
);


-- ========================================================
-- 2. FACT TABLES (Create these last)
-- ========================================================

-- Granular table for stacked bar charts and trend lines
CREATE TABLE Populations (
    year_key INT REFERENCES Years(year_key),
    metro_key INT REFERENCES Metros(metro_key),
    age_group_key INT REFERENCES AgeGroups(age_group_key),
    demographic_key INT REFERENCES Demographics(demographic_key),
    population_count INT NOT NULL,
    PRIMARY KEY (year_key, metro_key, age_group_key, demographic_key)
);

-- High-level summary table for scatter plots (Median Age vs. Growth %)
CREATE TABLE MetroMetrics (
    year_key INT REFERENCES Years(year_key),
    metro_key INT REFERENCES Metros(metro_key),
    total_population INT,
    median_age DECIMAL(4,1),     -- Pre-calculated non-additive metric
    growth_count INT,
    growth_percentage DECIMAL(5,2),
    PRIMARY KEY (year_key, metro_key)
);





-- ============================================================================
-- 1. BRONZE LAYER (Raw Tables - Staging No Constraints)
-- ============================================================================

CREATE TABLE bronze_cbsa_char (
    SUMLEV INT, CBSA INT, MDIV VARCHAR(50), NAME VARCHAR(255), LSAD VARCHAR(100), YEAR INT, AGEGRP INT,
    TOT_POP INT, TOT_MALE INT, TOT_FEMALE INT, WA_MALE INT, WA_FEMALE INT, BA_MALE INT, BA_FEMALE INT,
    IA_MALE INT, IA_FEMALE INT, AA_MALE INT, AA_FEMALE INT, NA_MALE INT, NA_FEMALE INT, TOM_MALE INT, TOM_FEMALE INT
);

CREATE TABLE bronze_cbsa_age (
    SUMLEV INT, CBSA INT, MDIV VARCHAR(50), NAME VARCHAR(255), LSAD VARCHAR(100), YEAR INT,
    POPESTIMATE INT, POPEST_MALE INT, POPEST_FEM INT, MEDIAN_AGE_TOT DECIMAL(4,1)
);

CREATE TABLE bronze_csa_char (
    SUMLEV INT, CSA INT, NAME VARCHAR(255), LSAD VARCHAR(100), YEAR INT, AGEGRP INT,
    TOT_POP INT, TOT_MALE INT, TOT_FEMALE INT
);
-- ============================================================================
-- 2. SILVER LAYER (Cleaned, Enriched Operational Views/Tables)
-- ============================================================================

CREATE TABLE silver_clean_demographics (
    CBSA INT, metro_name VARCHAR(150), state_code CHAR(2), YEAR INT, AGEGRP INT,
    TOT_POP INT, TOT_MALE INT, TOT_FEMALE INT
);

CREATE TABLE silver_clean_metrics (
    CBSA INT, metro_name VARCHAR(150), YEAR INT, POPESTIMATE INT,
    PriorYearPop INT, growth_count INT, growth_percentage DECIMAL(5,2), median_age DECIMAL(4,1)
);

-- ============================================================================
-- 3. GOLD LAYER (Production Dimensional Star Schema)
-- ============================================================================

CREATE TABLE gold_Years (
    year_key INT PRIMARY KEY,
    census_year INT NOT NULL
);

CREATE TABLE gold_Metros (
    metro_key INT PRIMARY KEY,
    metro_id VARCHAR(10), metro_name VARCHAR(150), state_code CHAR(2),
    latitude DECIMAL(9,6) NULL, longitude DECIMAL(9,6) NULL
);

CREATE TABLE gold_AgeGroups (
    age_group_key INT PRIMARY KEY,
    age_group VARCHAR(50)
);

CREATE TABLE gold_Demographics (
    demographic_key INT PRIMARY KEY, race_ethnicity VARCHAR(100), gender VARCHAR(20)
);

CREATE TABLE gold_Populations (
    year_key INT FOREIGN KEY REFERENCES gold_Years(year_key),
    metro_key INT FOREIGN KEY REFERENCES gold_Metros(metro_key),
    age_group_key INT FOREIGN KEY REFERENCES gold_AgeGroups(age_group_key),
    demographic_key INT FOREIGN KEY REFERENCES gold_Demographics(demographic_key),
    population_count INT NOT NULL,
    PRIMARY KEY (year_key, metro_key, age_group_key, demographic_key)
);

CREATE TABLE gold_MetroMetrics (
    year_key INT FOREIGN KEY REFERENCES gold_Years(year_key),
    metro_key INT FOREIGN KEY REFERENCES gold_Metros(metro_key),
    total_population INT, median_age DECIMAL(4,1) NULL, growth_count INT, growth_percentage DECIMAL(5,2),
    PRIMARY KEY (year_key, metro_key)
);

-- Expand growth percentage to hold up to 12 digits total, 4 past the decimal
ALTER TABLE silver_clean_metrics ALTER COLUMN growth_percentage DECIMAL(12,4);
ALTER TABLE gold_MetroMetrics ALTER COLUMN growth_percentage DECIMAL(12,4);

